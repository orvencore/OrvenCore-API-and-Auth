APP_NAME=OrvenCore API
APP_ENV=development
ORVENCORE_PUBLIC_URL=http://127.0.0.1:8000
ORVENCORE_CANONICAL_DOMAIN=orvencore.com
DATABASE_URL=sqlite:///./orvencore.db
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
AUTO_CREATE_TABLES=true
